{
    "layer": "top",
    "position": "top",
    "height": 25,

    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "network",
        // "cpu",
        // "memory",
        // "temperature",
        "custom/spotify",
        "custom/wkblayout",
        "battery",
        "tray",
        "clock#date",
        "clock#time"
    ],

    // Modules
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        // Connected to AC
        "format": "пѓ§  {icon}  {capacity}%", // Icon: bolt
        // Not connected to AC
        "format-discharging": "{icon}  {capacity}%",
        "format-icons": [
            "п‰„", // Icon: battery-full
            "п‰ѓ", // Icon: battery-three-quarters
            "п‰‚", // Icon: battery-half
            "п‰Ѓ", // Icon: battery-quarter
            "п‰Ђ"  // Icon: battery-empty
        ],
        "tooltip": true
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip": false
    },

    "clock#date": {
        "interval": 10,
        "format": "пЃі  {:%e %b %Y}", // Icon: calendar-alt
        "tooltip-format": "{:%e %B %Y}"
    },

    "cpu": {
        "interval": 5,
        "format": "п‹›  {usage}% ({load})", // Icon: microchip
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "custom/wkblayout": {
        // "format": "<span color='#11eec2'>рџ–‹</span> {}",
        "format": "п„њ  {}", // Icon: keyboard
        "interval": 30,
        "signal": 1,
        "exec": "wkblayout"
    },

    "custom/spotify": {
        "interval": 1,
        "return-type": "json",
        "exec": "~/.config/waybar/playerctl.sh",
        "exec-if": "pgrep spotify",
        "escape": true
    },

    "memory": {
        "interval": 5,
        "format": "п”ё  {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "п‡«  {essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "пћ–  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "вљ   Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">  {}</span>", // Icon: expand-arrows-alt
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{icon} {name}",
        "format-icons": {
            "1:www": "п¤‡", // Icon: firefox-browser
            "2:mail": "пЉ¶", // Icon: mail
            "3:editor": "п„Ў", // Icon: code
            "4:terminals": "п„ ", // Icon: terminal
            "5:portal": "п„ ", // Icon: terminal
            "urgent": "пЃЄ",
            "focused": "п†’",
            "default": "п„‘"
        }
    },

